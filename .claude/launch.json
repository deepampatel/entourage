{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "uvicorn", "openclaw.main:app", "--reload", "--port", "8000"],
      "port": 8000,
      "cwd": "packages/backend"
    },
    {
      "name": "frontend",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "runtimeArgs": ["/opt/homebrew/bin/npx", "vite"],
      "port": 5173,
      "cwd": "packages/frontend",
      "env": {"PATH": "/opt/homebrew/bin:/usr/bin:/bin"}
    }
  ]
}
